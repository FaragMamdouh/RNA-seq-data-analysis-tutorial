# Integrating NB3 and BM4
DefaultAssay(Day0) = "SCT"
DefaultAssay(Day60) = "SCT"
bm.list <- list(Day0, Day60)
bm.features <- SelectIntegrationFeatures(object.list = bm.list, nfeatures = 3000)
bm.list <- PrepSCTIntegration(object.list = bm.list, anchor.features = bm.features)

bm.anchors <- FindIntegrationAnchors(
  object.list = bm.list, 
  normalization.method = "SCT", 
  anchor.features = bm.features)

bm.integrated <- IntegrateData(anchorset = bm.anchors, 
                               normalization.method = "SCT")
DefaultAssay(bm.integrated) = "integrated"
#Dimensionality reduction and clustering
bm.integrated <- RunPCA(object = bm.integrated,
                        verbose = F)
for(i in c(20)){
  ElbowPlot(bm.integrated, ndims = 50)
  bm.integrated <- RunUMAP(object = bm.integrated,
                           dims = 1:i, verbose = FALSE)
  bm.integrated <- FindNeighbors(bm.integrated, reduction = "pca", dims = 1:i, verbose = FALSE)
  bm.integrated <- FindClusters(bm.integrated, resolution = c(seq(from = 0.1, to = 2.0, by = 0.1)), verbose = FALSE)
  print(clustree(x = bm.integrated, prefix = "integrated_snn_res.") + ggtitle(paste("clustree", i ,"PCs")))
}


