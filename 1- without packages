dim(data)

####calculating the fold change####
#(rows, columns)
#caculate the logged mean for each group
tum.mean = apply((log2(data+1))[,1:50], 1, mean)

norm.mean = apply((log2(data+1))[,51:dim(data)[2]], 1, mean)
View(norm.mean)
View(tum.mean)

#calculate the fold change by taking the difference between the two means
#the difference between logged means equl to the fold change instead of using
#division of unlogged data

# Calculate fold change (difference of log2 means)
fold <- tum.mean - norm.mean
View(fold)

# Set margins
par(mar = c(5, 5, 4, 2))

# Create histogram
hist(
  fold,
  breaks = 50,
  col = "#457B9D",
  border = "white",
  probability = TRUE,
  main = "Distribution of Log2 Fold Change",
  xlab = expression(Log[2]~Fold~Change~(Tumor - Normal)),
  ylab = "Density",
  cex.main = 1.4,
  cex.lab = 1.2
)

# Add density curve
lines(density(fold),
      col = "#E63946",
      lwd = 3)


# Add vertical lines
abline(v = 0, col = "black", lwd = 2)                      # no change reference
abline(v = mean(fold), col = "#2A9D8F", lwd = 2, lty = 2)  # mean FC

# Add legend
legend(
  "topright",
  legend = c("Density", "Mean Log2 FC", "No Change (0)"),
  col = c("#E63946", "#2A9D8F", "black"),
