library(ggplot2)


library(ggrepel)

# Add expression category column
result$gene <- rownames(result)
result$Expression <- "Not Significant"
result$Expression[result$p.adj < 0.05 & result$fold > 2]  <- "Upregulated"
result$Expression[result$p.adj < 0.05 & result$fold < -2] <- "Downregulated"

# Label top 10 up and down genes
top_genes <- rbind(
  head(result[result$Expression == "Upregulated",][order(-result[result$Expression == "Upregulated","fold"]),], 10),
  head(result[result$Expression == "Downregulated",][order(result[result$Expression == "Downregulated","fold"]),], 10)
)

# Plot
ggplot(result, aes(x = fold, y = -log10(p.adj), color = Expression)) +
  geom_point(alpha = 0.6, size = 1.8) +
  scale_color_manual(values = c("Upregulated" = "#E63946",
                                "Downregulated" = "#457B9D",
                                "Not Significant" = "grey60")) +
  geom_vline(xintercept = c(-2, 2), linetype = "dashed", color = "black") +
  geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "black") +
  geom_text_repel(data = top_genes, aes(label = gene), size = 3, max.overlaps = 20) +
  labs(title = "Volcano Plot - Tumor vs Normal (LUSC)",
       x = expression(Log[2]~Fold~Change),
       y = expression(-Log[10]~Adjusted~P-value)) +
  theme_bw(base_size = 13) +
  theme(legend.position = "right")



