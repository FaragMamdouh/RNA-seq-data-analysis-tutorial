library(clusterProfiler)
library(org.Hs.eg.db)

# Separate up and downregulated
up_genes   <- rownames(res.deg[res.deg$fold > 2, ])
down_genes <- rownames(res.deg[res.deg$fold < -2, ])

# Convert gene symbols to Entrez IDs
convert_ids <- function(genes) {
  bitr(genes, fromType = "SYMBOL", toType = "ENTREZID", OrgDb = org.Hs.eg.db)
}

up_entrez   <- convert_ids(up_genes)
down_entrez <- convert_ids(down_genes)
all_entrez  <- convert_ids(rownames(res.deg))

#---GO Enrichment---#
go_up <- enrichGO(gene = up_entrez$ENTREZID,
                  OrgDb = org.Hs.eg.db,
                  ont = "BP",
                  pAdjustMethod = "BH",
                  pvalueCutoff = 0.05,
                  readable = TRUE)

go_down <- enrichGO(gene = down_entrez$ENTREZID,
                    OrgDb = org.Hs.eg.db,
                    ont = "BP",
                    pAdjustMethod = "BH",
                    pvalueCutoff = 0.05,
                    readable = TRUE)

# Visualize
dotplot(go_up,   showCategory = 15, title = "GO BP - Upregulated Genes")
dotplot(go_down, showCategory = 15, title = "GO BP - Downregulated Genes")

#---KEGG Pathway---#
kegg_res <- enrichKEGG(gene = all_entrez$ENTREZID,
                       organism = "hsa",
                       pvalueCutoff = 0.05)

dotplot(kegg_res, showCategory = 15, title = "KEGG Pathway Enrichment")
